<Solution>
  <Configurations>
    <Platform Name="ARM64" />
    <Platform Name="x64" />
    <Platform Name="x86" />
  </Configurations>
  <Project Path="SnapRename/SnapRename.csproj">
    <Platform Solution="*|x64" Project="x64" />
    <Platform Solution="*|x86" Project="x86" />
    <Platform Solution="Debug|ARM64" Project="x64" />
    <Platform Solution="Release|ARM64" Project="ARM64" />
    <Deploy />
  </Project>
</Solution>
