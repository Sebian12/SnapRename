<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SnapRename.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SnapRename"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SnapRename">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/> <!--Settings button-->
            <RowDefinition Height="150"/> <!--Drag & Drop-->
            <RowDefinition Height="*"/> <!--File list-->
            <RowDefinition Height="auto"/> <!--Rename template-->
            <RowDefinition Height="auto"/> <!--Rename button-->
        </Grid.RowDefinitions>
        <Button 
            Content="Settings" 
            Grid.Row="0" 
            HorizontalAlignment="Stretch" 
            CornerRadius="5"
            Margin="10"/>

        <Border 
            AllowDrop="True" 
            CanDrag="True" 
            BorderThickness="1" 
            BorderBrush="#555" 
            CornerRadius="5" 
            Margin="10" 
            Grid.Row="1"
            Opacity="0.8"
            Tapped="DropZone_Tapped"
            Background="Transparent">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock 
                    Text="Click to select photos" 
                    FontSize="14" 
                    HorizontalAlignment="Center"/>
                <TextBlock 
                    Text="JPG, PNG, CR2, NEF" 
                    FontSize="12" 
                    HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        <ListView Margin="10" Grid.Row="2" x:Name="FileList">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:PhotoFile">
                    <StackPanel>
                        <TextBlock Text="{x:Bind OldName}"/>
                        <TextBlock Text="{x:Bind NewName}" Opacity="0.6"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="3" Margin="10">
            <TextBlock
                Text="Name template"/>
            <TextBox
                PlaceholderText="{}{YYYY}-{MM}-{DD}_{label}_{###}"/>
        </StackPanel>
        <Button 
            Content="Rename and save" 
            Grid.Row="4" 
            HorizontalAlignment="Stretch" 
            CornerRadius="5"
            Margin="10"/>
    </Grid>
</Window>
